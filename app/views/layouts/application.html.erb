<!DOCTYPE html>
<html data-theme="payload">
  <head>
    <title><%= content_for(:title) || "Payload" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Payload">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="app-body">
    <header class="topbar">
      <%= link_to root_path, class: "brand" do %>
        <span class="brand-flag">P</span>
        <span>Payload</span>
      <% end %>

      <% if signed_in? %>
        <div class="user-menu">
          <% if current_user.avatar_url.present? %>
            <%= image_tag current_user.avatar_url, alt: "", class: "avatar" %>
          <% else %>
            <span class="avatar avatar-fallback"><%= icon("user") %></span>
          <% end %>
          <span class="user-name"><%= current_user.display_name %></span>
          <%= button_to sign_out_path, method: :delete, class: "icon-button", title: "Sign out" do %>
            <%= icon("log-out") %>
          <% end %>
        </div>
      <% end %>
    </header>

    <% if flash.any? %>
      <div class="flash-stack">
        <% flash.each do |kind, message| %>
          <div class="flash <%= kind == "alert" ? "flash-alert" : "flash-notice" %>">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
